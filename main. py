
from flask import Flask, request, jsonify

app = Flask(__name__)

users = {}

@app.route("/")
def home():
    return "AI Trading SaaS LIVE on Render"

# REGISTER USER
@app.route("/register")
def register():
    user_id = request.args.get("user_id")

    if not user_id:
        return jsonify({"error": "missing user_id"})

    users[user_id] = {"vip": False}

    return jsonify({"status": "registered", "user_id": user_id})

# ACTIVATE VIP (manual for now)
@app.route("/activate")
def activate():
    user_id = request.args.get("user_id")

    if user_id in users:
        users[user_id]["vip"] = True
        return jsonify({"status": "VIP activated"})

    return jsonify({"error": "user not found"})

# SIGNALS
@app.route("/signals")
def signals():
    user_id = request.args.get("user_id")

    if user_id not in users or not users[user_id]["vip"]:
        return jsonify({"error": "VIP only"})

    return jsonify({
        "signal": "BUY",
        "price": 65000,
        "confidence": 0.78
    })

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=10000)
